PORT=3000
NODE_ENV=development

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=fastfood_user
DB_PASSWORD=change_me
DB_NAME=fastfood_db
# Optional if using socket auth:
# DB_SOCKET_PATH=/run/mysqld/mysqld.sock

JWT_SECRET=change-this-secret
JWT_EXPIRE=7d
BCRYPT_ROUNDS=10

# Set to true when app is behind a reverse proxy/load balancer
TRUST_PROXY=false
API_DOCS_ENABLED=true

# HTTPS/TLS (recommended for production)
HTTPS_ENABLED=false
HTTPS_PORT=3443
HTTPS_REDIRECT_HTTP=true
# Paths can be absolute or relative to project root
HTTPS_KEY_PATH=certs/server.key
HTTPS_CERT_PATH=certs/server.crt
# Optional chain/intermediate cert
HTTPS_CA_PATH=

# Global API throttling (DoS/flood protection)
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX_REQUESTS=300

# Authentication throttling (brute-force protection)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=20

# Per-user throttling for authenticated write actions
USER_ORDER_CREATE_RATE_LIMIT_WINDOW_MS=600000
USER_ORDER_CREATE_RATE_LIMIT_MAX_REQUESTS=10
USER_PAYMENT_INIT_RATE_LIMIT_WINDOW_MS=600000
USER_PAYMENT_INIT_RATE_LIMIT_MAX_REQUESTS=8

# Payment callback throttling (callback flooding protection)
PAYMENT_CALLBACK_RATE_LIMIT_WINDOW_MS=300000
PAYMENT_CALLBACK_RATE_LIMIT_MAX_REQUESTS=30
